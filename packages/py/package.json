{
  "name": "@metta-ts/py",
  "version": "1.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@metta-ts/core": "workspace:*",
    "@metta-ts/hyperon": "workspace:*"
  },
  "devDependencies": {
    "pythonia": "^1.2.6",
    "ws": "^7.5.10"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Python interop for MeTTa TS: PeTTa-style py-call and Hyperon-style py-atom over a bring-your-own CPython bridge (pythonia reference adapter).",
  "keywords": [
    "metta",
    "hyperon",
    "python",
    "interop",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/Meta-TypeScript-Talk.git",
    "directory": "packages/py"
  },
  "homepage": "https://github.com/MesTTo/Meta-TypeScript-Talk#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/Meta-TypeScript-Talk/issues"
  }
}
