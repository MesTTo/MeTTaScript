{
  "name": "@mettascript/py",
  "version": "2.0.3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pythonia": {
      "types": "./dist/pythonia.d.ts",
      "default": "./dist/pythonia.js"
    },
    "./pyodide": {
      "types": "./dist/pyodide.d.ts",
      "default": "./dist/pyodide.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/pythonia.ts src/pyodide.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@mettascript/core": "workspace:*",
    "@mettascript/hyperon": "workspace:*"
  },
  "devDependencies": {
    "pyodide": "314.0.2",
    "pythonia": "^1.2.6",
    "ws": "^7.5.10"
  },
  "peerDependencies": {
    "pyodide": "314.0.2",
    "pythonia": "^1.2.6"
  },
  "peerDependenciesMeta": {
    "pyodide": {
      "optional": true
    },
    "pythonia": {
      "optional": true
    }
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Python interop for MeTTaScript: PeTTa-style py-call and Hyperon-style py-atom over pythonia in Node or Pyodide in browsers.",
  "keywords": [
    "metta",
    "hyperon",
    "python",
    "interop",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTaScript.git",
    "directory": "packages/py"
  },
  "homepage": "https://github.com/MesTTo/MeTTaScript#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTaScript/issues"
  }
}
