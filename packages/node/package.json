{
  "name": "@metta-ts/node",
  "version": "1.1.5",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "metta-ts": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "default": "./dist/source.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/source.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@metta-ts/core": "workspace:*",
    "@metta-ts/prolog": "workspace:*",
    "@metta-ts/py": "workspace:*"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Node.js entry for MeTTa TS: the metta-ts CLI, file import!, optional Python/Prolog interop, and a worker-thread parallel matcher.",
  "keywords": [
    "metta",
    "hyperon",
    "cli",
    "atomspace",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTa-TS.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/MesTTo/MeTTa-TS#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTa-TS/issues"
  },
  "devDependencies": {
    "pythonia": "^1.2.6",
    "ws": "^7.5.10"
  },
  "peerDependencies": {
    "pythonia": "^1.2.6"
  },
  "peerDependenciesMeta": {
    "pythonia": {
      "optional": true
    }
  }
}
