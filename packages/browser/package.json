{
  "name": "@mettascript/browser",
  "version": "2.0.3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "default": "./dist/source.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "default": "./dist/host.js"
    },
    "./hyperpose-worker": {
      "types": "./dist/hyperpose-worker.d.ts",
      "default": "./dist/hyperpose-worker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/source.ts src/host.ts src/hyperpose-worker.ts --format esm --dts --clean --platform browser"
  },
  "dependencies": {
    "@mettascript/core": "workspace:*",
    "@mettascript/libraries": "workspace:*"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "./dist/hyperpose-worker.js"
  ],
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Browser entry for MeTTaScript with an in-memory virtual file system and optional host interop composition.",
  "keywords": [
    "metta",
    "hyperon",
    "browser",
    "atomspace",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTaScript.git",
    "directory": "packages/browser"
  },
  "homepage": "https://github.com/MesTTo/MeTTaScript#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTaScript/issues"
  }
}
