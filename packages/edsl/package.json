{
  "name": "@metta-ts/edsl",
  "version": "1.1.5",
  "author": "MesTTo",
  "license": "MIT",
  "description": "Ergonomic, typed TypeScript eDSL for MeTTa: term builders, tagged templates, host-interop builders, and auto-grounding of TypeScript values.",
  "keywords": [
    "metta",
    "hyperon",
    "edsl",
    "dsl",
    "term-rewriting",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./py": {
      "types": "./dist/py.d.ts",
      "default": "./dist/py.js"
    },
    "./prolog": {
      "types": "./dist/prolog.d.ts",
      "default": "./dist/prolog.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/py.ts src/prolog.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@metta-ts/hyperon": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTa-TS.git",
    "directory": "packages/edsl"
  },
  "homepage": "https://github.com/MesTTo/MeTTa-TS#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTa-TS/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
