{
  "name": "@metta-ts/grapher",
  "version": "1.1.7",
  "author": "MesTTo",
  "license": "MIT",
  "description": "MeTTa visual editor and reduction renderer for browser and Node.js, with node-graph and nested-block views.",
  "keywords": [
    "metta",
    "hyperon",
    "visual",
    "editor",
    "graph",
    "gif",
    "svg",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --platform browser && tsup src/node.ts --format esm --dts --platform node"
  },
  "dependencies": {
    "@metta-ts/hyperon": "workspace:*"
  },
  "devDependencies": {
    "gifenc": "1.0.3",
    "sharp": "^0.35.3"
  },
  "peerDependencies": {
    "gifenc": "^1.0.3",
    "sharp": "^0.35.3"
  },
  "peerDependenciesMeta": {
    "gifenc": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTa-TS.git",
    "directory": "packages/grapher"
  },
  "homepage": "https://github.com/MesTTo/MeTTa-TS#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTa-TS/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
