{
  "name": "@metta-ts/py",
  "version": "2.0.3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pyodide": {
      "types": "./dist/pyodide.d.ts",
      "default": "./dist/pyodide.js"
    },
    "./pythonia": {
      "types": "./dist/pythonia.d.ts",
      "default": "./dist/pythonia.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/pyodide.ts src/pythonia.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@mettascript/py": "workspace:*"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Compatibility shim for @mettascript/py.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTaScript.git",
    "directory": "packages/py"
  },
  "homepage": "https://github.com/MesTTo/MeTTaScript#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTaScript/issues"
  }
}
