{
  "name": "@metta-ts/node",
  "version": "2.5.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "default": "./dist/source.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/source.ts src/cli.ts src/debug-cli.ts src/metta-cli.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@mettascript/node": "workspace:*"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Compatibility shim for @mettascript/node.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTaScript.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/MesTTo/MeTTaScript#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTaScript/issues"
  },
  "bin": {
    "metta": "./dist/metta-cli.js",
    "metta-ts": "./dist/cli.js",
    "metta-debug": "./dist/debug-cli.js"
  }
}
