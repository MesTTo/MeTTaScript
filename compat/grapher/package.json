{
  "name": "@metta-ts/grapher",
  "version": "2.0.3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@mettascript/grapher": "workspace:*"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "Compatibility shim for @mettascript/grapher.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTaScript.git",
    "directory": "packages/grapher"
  },
  "homepage": "https://github.com/MesTTo/MeTTaScript#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTaScript/issues"
  }
}
